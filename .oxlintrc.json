{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true,
    "es2022": true
  },
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vitest"],
  "ignorePatterns": [
    "coverage/**",
    "dist/**",
    "node_modules/**",
    "testdata/**"
  ],
  "rules": {
    "no-unused-vars": "off",
    "no-console": "off",
    "no-shadow": "off"
  }
}
