{
  "name": "spa-deploy-action",
  "version": "1.2.1",
  "private": true,
  "description": "deploy your single page application to S3 with correct cache control",
  "keywords": [
    "actions",
    "aws",
    "deployment",
    "s3",
    "spa"
  ],
  "homepage": "https://github.com/islishude/spa-deploy-action",
  "bugs": {
    "url": "https://github.com/islishude/spa-deploy-action/issues"
  },
  "license": "MIT",
  "author": "islishude <islishude@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islishude/spa-deploy-action.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "vitest run --coverage",
    "format:write": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "package": "npm run typecheck && vite build",
    "package:watch": "npm run typecheck && vite build --watch",
    "pretest": "docker compose down && docker compose up -d --wait",
    "test": "vitest run --coverage; status=$?; make-coverage-badge --output-path ./badges/coverage.svg; exit $status",
    "posttest": "docker compose down",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "mime-types": "^3.0.1",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@github/local-action": "^7.0.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "make-coverage-badge": "^1.2.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
